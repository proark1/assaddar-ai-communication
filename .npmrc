# Network resilience for CI, Docker, and Railway builds. The default pnpm fetch
# timeout (60s) and 2 retries let a single slow npm-registry window fail an
# entire production build (observed: ERR_SOCKET_TIMEOUT during `railway up`).
# These raise the retry count and timeouts so transient registry hiccups recover
# instead of failing the deploy. They do not change which packages are installed.
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
