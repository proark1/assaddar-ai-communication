{
  "name": "@assaddar/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "backfill:embeddings": "tsx src/backfill-embeddings.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html --coverage.reportsDirectory=../../coverage/workers",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@assaddar/channels": "workspace:*",
    "@assaddar/core": "workspace:*",
    "@assaddar/db": "workspace:*",
    "@sentry/node": "^10.63.0",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
