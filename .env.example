NODE_ENV=development

# API
API_HOST=0.0.0.0
API_PORT=4000
API_BASE_URL=http://localhost:4000
ADMIN_API_TOKEN=change-me-dev-admin-token
WIDGET_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

# Database and queues
# Recommended: Supabase Postgres session pooler or direct Postgres connection.
# Use the dashboard Connect panel. For migrations, prefer direct or session pooler on port 5432.
# Example session pooler:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Optional local Postgres fallback:
# DATABASE_URL=postgres://assaddar:assaddar@localhost:5432/assaddar_ai_communication
REDIS_URL=redis://localhost:6379

# OpenAI provider abstraction. The MVP runs in grounded extractive mode without this key.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VOICE_MODEL=gpt-4o-mini-tts

# Channel credentials: keep real secrets in your secret manager.
META_APP_SECRET=
META_VERIFY_TOKEN=change-me-meta-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Voice
VOICE_PORT=4100
VOICE_PUBLIC_URL=https://your-voice-domain
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_FROM_NUMBER=
TWILIO_TRANSFER_PHONE_NUMBER=
TWILIO_VOICE_LANGUAGE=de-DE
TWILIO_VOICE_NAME=alice

# Admin dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
