NODE_ENV=development

# API
API_HOST=0.0.0.0
API_PORT=4000
API_BASE_URL=http://localhost:4000
ADMIN_API_TOKEN=change-me-dev-admin-token
WIDGET_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
# Global API rate limit (per source IP). Public auth/widget routes apply
# stricter per-route limits on top of this.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
# Trust N forwarded proxy hops so per-IP rate limiting and session-IP logging
# see the real client IP behind Railway's proxy. Leave empty/false in local dev.
# In production set to the number of trusted proxies (Railway = 1), or a CIDR
# allowlist. Never "true" unless every upstream hop is fully trusted.
TRUST_PROXY=

# Database and queues
# Recommended production setup: Supabase Postgres connection string for the API,
# workers, voice service, and migrations. This is the OWNER role (runs
# migrations and the trusted workers service).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require
# Optional least-privilege application role for the API so Postgres row-level
# security is actually enforced (the table owner bypasses RLS unless forced).
# Provision with scripts/create-app-role.sql, enforce with
# scripts/enable-force-rls.sql, then verify with `pnpm db:check`. When unset the
# API falls back to DATABASE_URL (RLS inert — see docs/security-gdpr.md).
APP_DATABASE_URL=
# Set to true to make `pnpm db:check` fail when RLS is NOT enforced for the app
# role (recommended in production once APP_DATABASE_URL is provisioned).
REQUIRE_DB_RLS=false

# Optional local Postgres fallback:
# DATABASE_URL=postgres://assaddar:assaddar@localhost:5432/assaddar_ai_communication
REDIS_URL=redis://localhost:6379

# OpenAI provider abstraction. The MVP runs in grounded extractive mode without this key.
# Setting OPENAI_API_KEY also enables optional hybrid keyword + semantic retrieval
# (embeddings via pgvector); run migrations and the embeddings.generate worker to backfill.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_TIMEOUT_MS=10000
# Optional override for OpenAI-compatible gateways/proxies.
OPENAI_BASE_URL=https://api.openai.com/v1

# Channel credentials: keep real secrets in your secret manager.
# Optional app-level encryption key for channel credentials stored in Postgres.
# Preferred formats: base64:<32-byte-base64> or hex:<64-hex-chars>.
CHANNEL_CREDENTIAL_MASTER_KEY=
# Required in production so Meta webhook POSTs can be verified with
# X-Hub-Signature-256.
META_APP_SECRET=
META_VERIFY_TOKEN=change-me-meta-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Voice
VOICE_PORT=4100
VOICE_PUBLIC_URL=https://your-voice-domain
# Domain used to build SIP targets for provider trunks, for example voice-edge.example.com.
VOICE_SIP_DOMAIN=
# HMAC secret shared by the SIP/RTP edge and POST /voice/turn.
VOICE_EDGE_SECRET=
VOICE_RATE_LIMIT_MAX=120
VOICE_RATE_LIMIT_WINDOW=1 minute
# Legacy Twilio route only. The main telephone path uses a German/EU SIP provider plus /voice/turn.
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_FROM_NUMBER=
TWILIO_TRANSFER_PHONE_NUMBER=
TWILIO_VOICE_LANGUAGE=de-DE
TWILIO_VOICE_NAME=alice

# Voice edge: self-hosted SIP/RTP edge for easybell inbound calls.
VOICE_EDGE_HTTP_PORT=4200
VOICE_EDGE_PUBLIC_IP=
VOICE_EDGE_SIP_BIND=0.0.0.0:5060
VOICE_EDGE_RTP_PORT_MIN=30000
VOICE_EDGE_RTP_PORT_MAX=30100
EASYBELL_SIP_REGISTRAR=voip.easybell.de
EASYBELL_SIP_USERNAME=
EASYBELL_SIP_PASSWORD=
EASYBELL_SIP_FROM_DOMAIN=voip.easybell.de
EASYBELL_PUBLIC_NUMBER=
VOICE_TURN_URL=https://your-voice-domain/voice/turn
VOICE_EDGE_ASSISTANT_ID=
GEMINI_API_KEY=
GEMINI_STT_MODEL=gemini-3.5-flash
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Kore
VOICE_LOCALE=de-DE

# Admin dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Auth (API server only; never expose service-role/secret keys publicly)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
